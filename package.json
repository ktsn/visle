{
  "name": "visle",
  "version": "0.4.3",
  "description": "Islands Architecture renderer for Vue.js",
  "keywords": [
    "Vue.js",
    "islands architecture",
    "multi-page application",
    "server side rendering",
    "template engine"
  ],
  "license": "MIT",
  "author": "Katashin",
  "repository": {
    "type": "git",
    "url": "https://github.com/ktsn/visle"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/server/index.js",
    "./internal": "./dist/server/internal.js",
    "./build": "./dist/build/index.js",
    "./dev": "./dist/dev/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vp test",
    "test:coverage": "vp test --coverage --coverage.reporter=lcov",
    "check": "vp check",
    "fmt": "vp fmt",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "bumpp package.json jsr.json",
    "prepare": "vp config"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/compiler-core": "^3.5.28",
    "connect": "^3.7.0",
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@babel/types": "7.29.0",
    "@types/connect": "3.4.38",
    "@types/diffable-html": "5.0.2",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "bumpp": "11.0.1",
    "changelogithub": "14.0.0",
    "diffable-html": "6.0.1",
    "happy-dom": "20.9.0",
    "oxc-minify": "0.127.0",
    "playwright": "1.59.1",
    "typescript": "6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.15",
    "vite-plus": "0.1.15",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.15",
    "vue": "3.5.33"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.15",
