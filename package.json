    "oxlint": "^1.42.0",
    "playwright": "^1.58.2",
    "rollup": "^4.55.2",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "vue": "^3.5.27"
  },
  "peerDependencies": {
