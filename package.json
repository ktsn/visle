{
  "name": "visle",
  "version": "0.4.1",
  "description": "Islands Architecture renderer for Vue.js",
  "keywords": [
    "Vue.js",
    "islands architecture",
    "multi-page application",
    "server side rendering",
    "template engine"
  ],
  "license": "MIT",
  "author": "Katashin",
  "repository": {
    "type": "git",
    "url": "https://github.com/ktsn/visle"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/server/index.js",
    "./internal": "./dist/server/internal.js",
    "./build": "./dist/build/index.js",
    "./dev": "./dist/dev/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vp test",
    "test:coverage": "vp test --coverage --coverage.reporter=lcov",
    "check": "vp check",
    "fmt": "vp fmt",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "bumpp package.json jsr.json",
    "prepare": "vp config"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/compiler-core": "^3.5.28",
    "connect": "^3.7.0",
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@babel/types": "7.29.0",
    "@types/connect": "3.4.38",
    "@types/diffable-html": "5.0.2",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/sanitize-html": "2.16.1",
    "@vitest/coverage-v8": "4.1.0",
    "bumpp": "11.0.1",
    "changelogithub": "14.0.0",
    "diffable-html": "6.0.1",
    "happy-dom": "20.8.4",
    "oxc-minify": "0.120.0",
    "playwright": "1.58.2",
    "rollup": "4.59.0",
    "typescript": "5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitepress": "2.0.0-alpha.16",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vue": "3.5.30"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
